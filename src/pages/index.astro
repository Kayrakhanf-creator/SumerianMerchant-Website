---
import Base from "../layouts/Base.astro";
import Hero from "../components/home/Hero.astro";
import Spine from "../components/home/Spine.astro";
import Scale from "../components/home/Scale.astro";
import ZigguratMoment from "../components/home/ZigguratMoment.astro";
import ComplaintMoment from "../components/home/ComplaintMoment.astro";
import Economy from "../components/home/Economy.astro";
import Characters from "../components/home/Characters.astro";
import Artifacts from "../components/home/Artifacts.astro";
import Mystery from "../components/home/Mystery.astro";
import Roadmap from "../components/home/Roadmap.astro";
import FinalCTA from "../components/home/FinalCTA.astro";
import CuneiformDivider from "../components/CuneiformDivider.astro";
import CatalogRail from "../components/CatalogRail.astro";

/**
 * Homepage — five unforgettable moments with quiet rooms between them:
 * 1 dawn hero → 2 the barley scale (playable) → the spine (routine) →
 * 3 the ziggurat → 4 the complaint tablet → living city → Ea-nāṣir →
 * regional collections → the mystery → wishlist.
 */
---

<Base>
  <CatalogRail />
  <Hero />
  <Scale />
  <Spine />
  <ZigguratMoment />
  <ComplaintMoment />
  <Economy />
  <Characters />
  <Artifacts />
  <Mystery />
  <CuneiformDivider />
  <Roadmap />
  <FinalCTA />
</Base>
