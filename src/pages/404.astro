---
import Base from "../layouts/Base.astro";
---

<Base title="Tablet missing">
  <div class="flex min-h-[70svh] flex-col items-center justify-center px-6 pt-24 text-center">
    <div class="tablet striated max-w-md px-10 py-12">
      <p class="impressed font-display text-6xl text-[#33200f]">404</p>
      <p class="impressed mt-4 font-display text-xl text-[#33200f]">This tablet is missing.</p>
      <p class="mt-3 text-sm text-[#4a2c15]">
        Broken in transit, or never written. The scribes have been notified.
      </p>
    </div>
    <a href="/" class="mt-10 text-sand-300 underline underline-offset-4 hover:text-barley-400">
      Return to the shop
    </a>
  </div>
</Base>
