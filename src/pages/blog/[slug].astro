---
import Base from "../../layouts/Base.astro";
import CuneiformDivider from "../../components/CuneiformDivider.astro";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

interface Props {
  post: CollectionEntry<"blog">;
}
const { post } = Astro.props;
const { Content } = await render(post);

const formatDate = (iso: string) => {
  const d = new Date(iso);
  return Number.isNaN(d.getTime())
    ? iso
    : d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
};
---

<Base title={post.data.title} description={post.data.excerpt}>
  <article class="mx-auto max-w-3xl px-6 pb-24 pt-36">
    <a href="/blog" class="text-sm text-sand-300/60 transition-colors hover:text-barley-400">
      ← All entries
    </a>
    <p class="mt-10 text-xs uppercase tracking-[0.22em] text-sand-300/45">
      {formatDate(post.data.date)}
    </p>
    <h1
      class="mt-3 max-w-[20ch] font-display text-4xl leading-[1.08] text-sand-200 [text-wrap:balance] md:text-5xl"
    >
      {post.data.title}
    </h1>
    <CuneiformDivider class="mt-8 justify-start" />
    <div class="prose-sumer mt-8">
      <Content />
    </div>
  </article>
</Base>
