---
import Base from "../../layouts/Base.astro";
import PageHeader from "../../components/PageHeader.astro";
import Reveal from "../../components/Reveal.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort((a, b) => (a.data.date < b.data.date ? 1 : -1));

const formatDate = (iso: string) => {
  const d = new Date(iso);
  return Number.isNaN(d.getTime())
    ? iso
    : d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
};
---

<Base
  title="Development Blog"
  description="Design notes from the counter — how Sumerian Merchant is being built."
>
  <PageHeader eyebrow="Development blog" title="Notes from the counter.">
    <p slot="lead">
      Design decisions, weights and measures, and the occasional complaint. Posts are plain
      markdown files in <code class="text-barley-400">src/content/blog</code> — add one and it
      appears here at build time.
    </p>
  </PageHeader>
  <div class="mx-auto max-w-3xl px-6 py-20">
    <ul class="space-y-4">
      {
        posts.map((post, i) => (
          <li>
            <Reveal delay={i * 60}>
              <a
                href={`/blog/${post.id}`}
                class="group block rounded-xl border border-brick-900 px-7 py-7 transition-colors hover:border-copper-500/40 hover:bg-brick-950"
              >
                <p class="text-xs uppercase tracking-[0.22em] text-sand-300/45">
                  {formatDate(post.data.date)}
                </p>
                <h2 class="mt-2 font-display text-2xl text-sand-200 transition-colors group-hover:text-barley-400">
                  {post.data.title}
                </h2>
                <p class="mt-3 max-w-[58ch] leading-relaxed text-sand-300/70">{post.data.excerpt}</p>
              </a>
            </Reveal>
          </li>
        ))
      }
    </ul>
    {posts.length === 0 ? <p class="text-sand-300/60">No entries yet. The scribe is busy.</p> : null}
  </div>
</Base>
