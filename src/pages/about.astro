---
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";
import Reveal from "../components/Reveal.astro";
import WishlistButton from "../components/WishlistButton.astro";

const PILLARS = [
  ["Living Ancient City", "The city trades, worships, gossips, and starves with or without you. You are one counter in it."],
  ["Meaningful Trading", "A sale is never just barley changing hands. It's a relationship opening — or closing."],
  ["Social Progression", "There is no experience bar. There is a city, and what it thinks of you."],
  ["Historical Immersion", "Clay tablets, balance scales, barley money, state prices. The texture is real."],
  ["Mystery", "The surface is warm and ordinary. What's underneath takes its time."],
] as const;
---

<Base
  title="About"
  description="What Sumerian Merchant is, what it isn't, and why it's set four thousand years ago."
>
  <PageHeader eyebrow="About the game" title="I am really a merchant living in Ancient Mesopotamia.">
    <p slot="lead">
      That sentence is the whole design brief. Everything in Sumerian Merchant exists to make it
      true.
    </p>
  </PageHeader>

  <div class="mx-auto max-w-6xl px-6 py-20">
    <div class="max-w-[62ch] space-y-6 text-lg leading-relaxed text-sand-300/90">
      <p>
        Sumerian Merchant is a first-person merchant simulator set in Mesopotamia around 2000 BCE.
        You are a state-appointed trader with a small shop, a bronze balance scale, and a city full
        of people who need things. You order goods, stock shelves, weigh barley payments by hand,
        negotiate, accept pawned heirlooms, file official complaints on clay, pay your taxes, and —
        slowly — become someone.
      </p>
      <p>
        The goal is not to get rich. Money keeps the shop open. The goal is to be trusted,
        respected, and eventually powerful within one of the world&rsquo;s first civilizations.
        Influence is the real currency, and the city keeps the ledger.
      </p>
      <p>
        You&rsquo;ve stocked shelves in a supermarket sim. This is that satisfaction, four thousand
        years earlier — when money was grain, receipts were clay, and a bad review was carved
        somewhere it couldn&rsquo;t be deleted.
      </p>
    </div>

    <h2 class="mt-24 font-display text-3xl text-sand-200">Five pillars</h2>
    <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {
        PILLARS.map(([name, text], i) => (
          <Reveal delay={i * 60}>
            <div class="tablet-dark h-full px-6 py-6">
              <p class="flex items-baseline gap-3 font-display text-xl text-barley-400">
                <span aria-hidden="true" class="text-sm text-copper-500">
                  {"𒁹".repeat(i + 1)}
                </span>
                {name}
              </p>
              <p class="mt-3 text-sm leading-relaxed text-sand-300/70">{text}</p>
            </div>
          </Reveal>
        ))
      }
    </div>

    <div class="mt-24 grid gap-12 md:grid-cols-2">
      <div>
        <h2 class="font-display text-2xl text-sand-200">What it is</h2>
        <p class="mt-5 max-w-[48ch] leading-relaxed text-sand-300/80">
          A tactile shop sim with real weight to its payments. A social climb through seven classes
          of customer. A legal system you can use and that can be used on you. A calendar that
          changes what walks through your door. And a long, quiet mystery for those who read the
          records closely.
        </p>
      </div>
      <div>
        <h2 class="font-display text-2xl text-sand-200">What it isn&rsquo;t</h2>
        <p class="mt-5 max-w-[48ch] leading-relaxed text-sand-300/80">
          Not a combat game. Not a city builder. Not a museum audio guide. Historical texture
          matters here, but play comes first — we take deliberate liberties, and we take them
          knowingly. Ea-nāṣir&rsquo;s famous copper is a few centuries adrift. He doesn&rsquo;t
          mind.
        </p>
      </div>
    </div>

    <div class="mt-24 flex flex-col items-start gap-5 border-t border-brick-900 pt-14">
      <p class="max-w-[52ch] text-lg leading-relaxed text-sand-300/90">
        Built in Unity by a small team that thinks the oldest customer complaint in history
        deserves a game.
      </p>
      <WishlistButton />
    </div>
  </div>
</Base>
