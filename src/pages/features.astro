---
import Base from "../layouts/Base.astro";
import PageHeader from "../components/PageHeader.astro";
import Reveal from "../components/Reveal.astro";
import WishlistButton from "../components/WishlistButton.astro";

const FEATURES: Array<{ k: string; name: string; text: string }> = [
  {
    k: "01",
    name: "Shop management",
    text: "Order from the state at fixed prices, take delivery, carry every jar to its shelf with your own hands. No magic inventory. If it's on the shelf, you put it there.",
  },
  {
    k: "02",
    name: "The balance scale",
    text: "Barley is money and money is weighed. Stone weights on one pan, the customer's barley on the other, your thumb on the pour. Your weight set grows with your standing — from single-measure stones to the great weights that settle a fortune in one motion. Silver is for the big days, and silver is weighed too.",
  },
  {
    k: "03",
    name: "Buying from citizens",
    text: "People bring you things: copper, jewelry, tools, weapons, statues, seals. Some are treasures. Some are trouble. The price you offer is yours to defend.",
  },
  {
    k: "04",
    name: "Inspection",
    text: "Turn a piece over in your hands. Early on, its nature is plain. Later, condition and authenticity hide — and you'll need tools, light, and experience to catch a fake before the inspector catches you.",
  },
  {
    k: "05",
    name: "Negotiation",
    text: "A peasant haggles from need. A merchant presses your margin for sport. A noble never argues the price — only the quality. Read who is standing at your counter.",
  },
  {
    k: "06",
    name: "The pawn counter",
    text: "Citizens leave collateral — a necklace, a sickle, a father's seal — for barley in hand. State-set interest, a fixed redemption window. If they return, it's theirs. If they don't, it's yours.",
  },
  {
    k: "07",
    name: "Official complaints",
    text: "False copper, theft, fraud, broken contracts: press your case into clay, seal it, and submit it. Win, and be rewarded. Lose, and pay for the tablet. The same law is available to everyone — including the people you've wronged.",
  },
  {
    k: "08",
    name: "Influence",
    text: "The real progression system. Influence decides who visits your shop, what they'll show you, which districts open, and how high society lets you climb — seven classes, from peasant to the royal house. Win people over; the city follows.",
  },
  {
    k: "09",
    name: "Calendar & seasons",
    text: "A 28-day year in four seasons, each closed by a ritual. Drought, harvest, festival, disease, caravans, war — the calendar decides prices, moods, and who has reason to knock.",
  },
  {
    k: "10",
    name: "Historical artifacts",
    text: "Wealth eventually brings history to your counter. Collect it, complete regional collections, and watch new cultures — and their strange, wonderful goods — find their way to your city.",
  },
  {
    k: "11",
    name: "Ea-nāṣir",
    text: "A helpful merchant with a questionable ingot. The rest, you'll learn at the counter.",
  },
  {
    k: "12",
    name: "The records",
    text: "At first, your work is simple. Then the rumors begin. We're not saying more.",
  },
];
---

<Base
  title="Features"
  description="The balance scale, the complaint tablets, the pawn counter, the seasons — every system in Sumerian Merchant."
>
  <PageHeader eyebrow="Systems" title="Everything at your counter.">
    <p slot="lead">
      Twelve systems, one shop. Each of them feeds the same ledger: what the city thinks of you.
    </p>
  </PageHeader>

  <div class="mx-auto max-w-6xl px-6 py-20">
    <ol class="grid gap-x-12 gap-y-2 md:grid-cols-2">
      {
        FEATURES.map((f, i) => (
          <li>
            <Reveal delay={(i % 2) * 60}>
              <div class="border-b border-brick-900 py-8">
                <p class="flex items-baseline gap-4">
                  <span aria-hidden="true" class="font-mono text-xs text-copper-500">
                    {f.k}
                  </span>
                  <span class="font-display text-2xl text-sand-200">{f.name}</span>
                </p>
                <p class="mt-3 max-w-[52ch] leading-relaxed text-sand-300/75">{f.text}</p>
              </div>
            </Reveal>
          </li>
        ))
      }
    </ol>

    <div class="mt-20 flex justify-center">
      <WishlistButton size="lg" />
    </div>
  </div>
</Base>
