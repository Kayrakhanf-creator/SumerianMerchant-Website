---
import SectionHead from "../SectionHead.astro";

/**
 * MOMENT 2 — THE BARLEY SCALE. Not a video of the mechanic: the mechanic.
 * Hold the sack to pour real barley into the pan; the bronze beam answers.
 * Land within tolerance and the trade is called fair. Ships balanced for
 * no-JS / reduced-motion visitors (controls hide themselves).
 */
const GRAINS: Array<[number, number, number, string]> = [
  [374, 181, 3.4, "#e0ab4e"], [382, 178, 3.8, "#d29a36"], [391, 180, 3.5, "#b07d24"],
  [399, 181, 3.2, "#e0ab4e"], [406, 182, 3.0, "#d29a36"], [378, 174, 3.2, "#b07d24"],
  [386, 172, 3.6, "#e0ab4e"], [395, 173, 3.4, "#d29a36"], [403, 176, 3.1, "#b07d24"],
  [382, 167, 3.0, "#d29a36"], [390, 166, 3.3, "#e0ab4e"], [398, 169, 2.9, "#b07d24"],
  [386, 161, 2.8, "#e0ab4e"], [394, 162, 2.7, "#d29a36"], [390, 157, 2.6, "#b07d24"],
  [384, 156, 2.5, "#e0ab4e"], [397, 155, 2.5, "#d29a36"], [390, 150, 2.4, "#e0ab4e"],
];
---

<section id="scale" class="relative overflow-hidden bg-brick-950 py-24 md:py-32">
  <div class="mx-auto grid max-w-6xl items-center gap-12 px-6 md:grid-cols-[5fr_7fr]">
    <div>
      <SectionHead no="02" label="Signature mechanic — try it" title="Payment has weight." size="lg" />
      <p class="mt-6 max-w-[40ch] text-lg leading-relaxed text-sand-300/90">
        No coins. No floating numbers. The stones sit on one pan — you pour
        barley into the other until the beam believes you.
      </p>
      <p
        id="sc-caption"
        aria-live="polite"
        class="mt-8 min-h-[2.2rem] font-display text-2xl text-barley-400"
      >
        Hold the sack. Pour.
      </p>
      <div class="scale-controls mt-6 flex flex-wrap items-center gap-3">
        <button
          type="button"
          id="sc-pour"
          class="select-none rounded-xl border border-barley-600 bg-barley-500 px-6 py-3.5 font-display text-lg font-semibold text-bitumen shadow-[0_6px_0_-2px_#7c5628] transition-transform active:translate-y-0.5"
        >
          ⌛ Hold to pour
        </button>
        <button
          type="button"
          id="sc-scoop"
          class="rounded-xl border border-sand-300/25 px-5 py-3.5 font-display text-base text-sand-200 transition-colors hover:border-barley-500/60"
        >
          Scoop back
        </button>
        <button type="button" id="sc-reset" class="px-2 text-sm text-sand-300/50 underline-offset-4 hover:underline">
          reset
        </button>
      </div>
      <p class="mt-6 text-xs text-sand-300/45">
        In game, your weight set grows with your standing — 1 · 2 · 5 · 10 · 25 · 50, and up.
      </p>
    </div>

    <div class="plate relative px-4 pb-5 pt-6 md:px-6">
      <svg
        viewBox="40 60 440 320"
        role="img"
        aria-label="A bronze balance scale — stone weights against poured barley"
        class="mx-auto w-full max-w-[560px] drop-shadow-[0_30px_40px_rgba(0,0,0,0.55)]"
      >
        <defs>
          <linearGradient id="bronzeg" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#b08749"></stop>
            <stop offset="0.5" stop-color="#966d36"></stop>
            <stop offset="1" stop-color="#6d4b22"></stop>
          </linearGradient>
          <linearGradient id="stoneg" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#93826d"></stop>
            <stop offset="1" stop-color="#6e5a44"></stop>
          </linearGradient>
        </defs>

        <rect x="60" y="356" width="400" height="13" rx="4" fill="#3d2b1e"></rect>
        <rect x="60" y="352" width="400" height="5" rx="2" fill="#553c28"></rect>
        <path d="M230 356 L290 356 L277 324 L243 324 Z" fill="url(#bronzeg)"></path>
        <rect x="254" y="118" width="12" height="210" rx="3" fill="url(#bronzeg)"></rect>

        <g id="sc-tick">
          <path d="M260 96 l8 11 -8 11 -8 -11 Z" fill="#e0ab4e"></path>
          <circle cx="260" cy="107" r="16" fill="#e0ab4e" opacity="0.18"></circle>
        </g>

        {/* pour stream — visible while pouring */}
        <line id="sc-stream" x1="390" y1="96" x2="390" y2="150" stroke="#d29a36" stroke-width="5" stroke-dasharray="3 6" opacity="0"></line>
        {/* the sack, tipped above the right pan */}
        <g id="sc-sack">
          <path d="M356 74 q26 -18 52 -2 l10 18 q-30 12 -64 2 Z" fill="#4a3a26" stroke="#33200f" stroke-width="2"></path>
          <path d="M410 72 q8 2 8 10" stroke="#33200f" stroke-width="3" fill="none"></path>
        </g>

        <g id="sc-beam">
          <rect x="118" y="113" width="284" height="10" rx="5" fill="url(#bronzeg)"></rect>
          <circle cx="260" cy="118" r="9" fill="#6d4b22"></circle>
          <circle cx="260" cy="118" r="4" fill="#33200f"></circle>

          <g id="sc-left">
            <g stroke="#7c5628" stroke-width="2">
              <line x1="130" y1="122" x2="106" y2="184"></line>
              <line x1="130" y1="122" x2="154" y2="184"></line>
            </g>
            <path d="M96 184 h68 a34 15 0 0 1 -68 0 Z" fill="url(#bronzeg)" stroke="#5c3f1e" stroke-width="1"></path>
            <g>
              <rect x="112" y="168" width="36" height="17" rx="3" fill="url(#stoneg)"></rect>
              <text x="130" y="180" text-anchor="middle" font-size="9" fill="#2b2118" font-weight="700">50</text>
              <rect x="117" y="154" width="26" height="14" rx="3" fill="url(#stoneg)"></rect>
              <text x="130" y="164" text-anchor="middle" font-size="8" fill="#2b2118" font-weight="700">25</text>
              <rect x="121" y="143" width="18" height="11" rx="2.5" fill="url(#stoneg)"></rect>
              <text x="130" y="151" text-anchor="middle" font-size="7" fill="#2b2118" font-weight="700">10</text>
            </g>
          </g>

          <g id="sc-right">
            <g stroke="#7c5628" stroke-width="2">
              <line x1="390" y1="122" x2="366" y2="184"></line>
              <line x1="390" y1="122" x2="414" y2="184"></line>
            </g>
            <path d="M356 184 h68 a34 15 0 0 1 -68 0 Z" fill="url(#bronzeg)" stroke="#5c3f1e" stroke-width="1"></path>
            <g id="sc-grains">
              {GRAINS.map(([cx, cy, r, c]) => <circle class="sc-grain" cx={cx} cy={cy} r={r} fill={c} />)}
            </g>
          </g>
        </g>
      </svg>
      <p class="plate-cap">Plate II · The stones total 85 — the beam does not lie</p>
    </div>
  </div>
</section>

<style>
  @media (prefers-reduced-motion: reduce) {
    .scale-controls {
      display: none;
    }
  }
</style>

<script>
  import { gsap } from "gsap";

  const beam = document.getElementById("sc-beam");
  const left = document.getElementById("sc-left");
  const right = document.getElementById("sc-right");
  const tick = document.getElementById("sc-tick");
  const stream = document.getElementById("sc-stream");
  const caption = document.getElementById("sc-caption");
  const grains = Array.from(document.querySelectorAll<SVGCircleElement>(".sc-grain"));
  const pourBtn = document.getElementById("sc-pour");
  const scoopBtn = document.getElementById("sc-scoop");
  const resetBtn = document.getElementById("sc-reset");
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!reduce && beam && left && right && tick && caption && pourBtn) {
    const TARGET = 85, TOL = 5, MAX = 130;
    let barley = 0;
    let pouring = false;
    let settled = false;

    const angleFor = () => Math.max(-12, Math.min(12, (barley - TARGET) * 0.16));
    const state = { a: 0 };

    const render = () => {
      gsap.to(state, {
        a: angleFor(),
        duration: 0.5,
        ease: "power2.out",
        overwrite: true,
        onUpdate: () => {
          gsap.set(beam, { rotation: state.a, svgOrigin: "260 120" });
          gsap.set(left, { rotation: -state.a, svgOrigin: "130 120" });
          gsap.set(right, { rotation: -state.a, svgOrigin: "390 120" });
        },
      });
      const show = Math.round((barley / MAX) * grains.length);
      grains.forEach((g, i) => (g.style.opacity = i < show ? "1" : "0"));
      const diff = barley - TARGET;
      const level = Math.abs(diff) <= TOL;
      gsap.to(tick, { opacity: level ? 1 : 0.15, duration: 0.3 });
      if (level && !settled && barley > 0) {
        settled = true;
        caption.textContent = "Level. Fair trade.";
        gsap.fromTo(caption, { scale: 1.25, rotation: -3 }, { scale: 1, rotation: 0, duration: 0.3, ease: "power4.in" });
      } else if (!level) {
        settled = false;
        caption.textContent =
          barley === 0 ? "Hold the sack. Pour." : diff < 0 ? "Keep pouring…" : "Too heavy. Scoop some back.";
      }
    };

    // start empty
    grains.forEach((g) => (g.style.opacity = "0"));
    gsap.set(tick, { opacity: 0.15 });
    state.a = -12;
    gsap.set(beam, { rotation: -12, svgOrigin: "260 120" });
    gsap.set(left, { rotation: 12, svgOrigin: "130 120" });
    gsap.set(right, { rotation: 12, svgOrigin: "390 120" });

    let timer: ReturnType<typeof setInterval> | null = null;
    const startPour = () => {
      if (pouring) return;
      pouring = true;
      if (stream) stream.style.opacity = "1";
      timer = setInterval(() => {
        barley = Math.min(MAX, barley + 2.4);
        render();
        if (barley >= MAX) stopPour();
      }, 50);
    };
    const stopPour = () => {
      pouring = false;
      if (stream) stream.style.opacity = "0";
      if (timer) clearInterval(timer);
      timer = null;
    };

    pourBtn.addEventListener("pointerdown", (e) => { e.preventDefault(); startPour(); });
    for (const ev of ["pointerup", "pointerleave", "pointercancel"]) pourBtn.addEventListener(ev, stopPour);
    pourBtn.addEventListener("keydown", (e) => {
      if ((e.key === " " || e.key === "Enter") && !e.repeat) { e.preventDefault(); startPour(); }
    });
    pourBtn.addEventListener("keyup", (e) => {
      if (e.key === " " || e.key === "Enter") stopPour();
    });
    scoopBtn?.addEventListener("click", () => { barley = Math.max(0, barley - 7); render(); });
    resetBtn?.addEventListener("click", () => { barley = 0; settled = false; render(); });
  }
</script>
