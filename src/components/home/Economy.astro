---
import SectionHead from "../SectionHead.astro";

/**
 * A LIVING ECONOMY — the market as a chart carved on the counting-house
 * wall. Rising stretches run GREEN, falling stretches run RED — you feel
 * the year before you read it. At WAR the record forks: two dashed
 * roads, and which one is yours depends on how you played.
 */
const UP = "#5a9e63";
const DOWN = "#b0492f";

const drought = `<g><circle cx="30" cy="14" r="7" fill="none" stroke-width="2.5"/><path d="M8 34 l8 -5 6 5 8 -6 8 6 6 -4" fill="none" stroke-width="2.5" stroke-linecap="round"/><path d="M22 34 l3 8 M40 33 l-2 8" fill="none" stroke-width="2" stroke-linecap="round"/></g>`;
const harvest = `<g stroke-width="2.5" stroke-linecap="round" fill="none"><path d="M30 42 V16"/><path d="M30 20 l-8 -7 M30 20 l8 -7 M30 28 l-9 -6 M30 28 l9 -6 M30 36 l-9 -5 M30 36 l9 -5"/></g>`;
const festival = `<g stroke-width="2.5" stroke-linecap="round"><path d="M14 40 V12 M46 40 V12" fill="none"/><path d="M14 14 h14 l-4 5 4 5 h-14 Z" fill="currentColor" stroke="none"/><path d="M46 18 h-12 l3.5 4.5 -3.5 4.5 h12 Z" fill="currentColor" stroke="none"/></g>`;
const disease = `<g stroke-width="2.5" stroke-linecap="round" fill="none"><path d="M12 42 V22 l18 -10 18 10 v20"/><rect x="24" y="28" width="12" height="14"/><path d="M24 28 l12 14 M36 28 l-12 14"/></g>`;
const caravan = `<g stroke-width="2.5" stroke-linecap="round" fill="none"><path d="M10 40 h40"/><path d="M16 40 v-8 q6 -10 12 0 q2 -12 12 -4 v12"/><path d="M40 28 q6 -2 8 4"/></g>`;
const war = `<g stroke-width="2.5" stroke-linecap="round" fill="none"><path d="M14 46 L34 22"/><path d="M38 18 L46 10 M38 18 l-2 6 M38 18 l-6 2"/><path d="M34 22 l4 -4" stroke-dasharray="2 4"/></g>`;

type Pt = { x: number; y: number; name: string; icon: string; iconSide: "above" | "below" };
const PTS: Pt[] = [
  { x: 190, y: 226, name: "Drought", icon: drought, iconSide: "above" },
  { x: 330, y: 252, name: "Fertile Harvest", icon: harvest, iconSide: "above" },
  { x: 470, y: 128, name: "Festival", icon: festival, iconSide: "below" },
  { x: 610, y: 208, name: "Disease", icon: disease, iconSide: "above" },
  { x: 750, y: 106, name: "Trade Caravan", icon: caravan, iconSide: "below" },
];
const START = { x: 60, y: 172 };
const WARX = 900;

// build colored segments: red when falling, green when rising
const nodes = [START, ...PTS];
const segs = nodes.slice(1).map((p, i) => {
  const a = nodes[i];
  return { x1: a.x, y1: a.y, x2: p.x, y2: p.y, c: p.y > a.y ? DOWN : UP };
});
---

<section id="economy" class="relative py-24 md:py-36">
  <div class="mx-auto max-w-6xl px-6">
    <SectionHead no="06" label="A living economy" title="The city changes the price." />
    <p class="mt-6 max-w-[54ch] text-lg leading-relaxed text-sand-300/90">
      A drought changes barley. A festival changes demand. A caravan changes supply. A war changes
      everything.
    </p>

    <div class="plate relative mt-14 overflow-hidden px-4 py-8 md:px-8">
      <p class="flex items-center justify-between px-2 text-[0.62rem] uppercase tracking-[0.3em] text-sand-300/45">
        <span>Market record · one year</span>
        <span class="flex items-center gap-4 normal-case tracking-normal">
          <span class="flex items-center gap-1.5 text-xs" style={`color:${UP}`}><span class="inline-block h-[3px] w-5 rounded" style={`background:${UP}`}></span>rises</span>
          <span class="flex items-center gap-1.5 text-xs" style={`color:${DOWN}`}><span class="inline-block h-[3px] w-5 rounded" style={`background:${DOWN}`}></span>falls</span>
        </span>
      </p>
      <svg
        id="eco-chart"
        viewBox="0 0 960 348"
        role="img"
        aria-label="A market chart: drought and harvest pull the line down in red, festival lifts it in green, disease drops it, a caravan lifts it again — and at war the line forks into a green road up and a red road down"
        class="mt-2 w-full"
      >
        <line x1="40" y1="172" x2="920" y2="172" stroke="#46311f" stroke-width="1.5" stroke-dasharray="3 7" opacity="0.6"></line>
        <text x="44" y="190" font-size="12" fill="#8f7f5f" letter-spacing="2">STEADY</text>

        {/* colored segments */}
        {
          segs.map((s) => (
            <line class="eco-seg" x1={s.x1} y1={s.y1} x2={s.x2} y2={s.y2} stroke={s.c} stroke-width="4" stroke-linecap="round" />
          ))
        }

        {/* WAR fork — green road up, red road down */}
        <g id="eco-fork">
          <path d={`M750 106 L${WARX} 44`} fill="none" stroke={UP} stroke-width="3.5" stroke-dasharray="7 8" stroke-linecap="round"></path>
          <path d={`M750 106 L${WARX} 262`} fill="none" stroke={DOWN} stroke-width="3.5" stroke-dasharray="7 8" stroke-linecap="round"></path>
          <path d={`M${WARX} 44 l-13 -1 m13 1 l-8 10`} stroke={UP} stroke-width="3.5" fill="none" stroke-linecap="round"></path>
          <path d={`M${WARX} 262 l-13 1 m13 -1 l-8 -10`} stroke={DOWN} stroke-width="3.5" fill="none" stroke-linecap="round"></path>
        </g>

        {/* nodes + icons */}
        <circle cx={START.x} cy={START.y} r="5" fill="#8f7f5f"></circle>
        {
          PTS.map((p, i) => (
            <g class="eco-node">
              <circle cx={p.x} cy={p.y} r="7" fill="#171210" stroke={i === 2 || i === 4 ? UP : DOWN} stroke-width="2.5" />
              <g
                class="text-copper-400"
                transform={`translate(${p.x - 20}, ${p.iconSide === "above" ? p.y - 74 : p.y + 16}) scale(0.67)`}
                stroke="currentColor"
                set:html={p.icon}
              />
            </g>
          ))
        }
        <g class="eco-node">
          <g class="text-copper-400" transform={`translate(${WARX - 44}, 128) scale(0.75)`} stroke="currentColor" set:html={war} />
        </g>

        {/* titles only */}
        {
          PTS.map((p) => (
            <text class="max-md:hidden" x={p.x} y="330" text-anchor="middle" font-size="17" fill="#e9dbbc" font-weight="600">
              {p.name}
            </text>
          ))
        }
        <text class="max-md:hidden" x={WARX - 10} y="330" text-anchor="middle" font-size="17" fill="#e9dbbc" font-weight="600">War</text>
      </svg>

      {/* mobile: titles as a simple row */}
      <p class="mt-3 px-2 text-sm leading-relaxed text-sand-300/60 md:hidden">
        Drought · Fertile Harvest · Festival · Disease · Trade Caravan · War
      </p>
      <p class="plate-cap">Plate VI · Market record — one year in the city</p>
    </div>

    <p class="mt-8 text-center text-sm text-sand-300/50">
      Your companion hears things early. Listen to him.
    </p>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const chart = document.getElementById("eco-chart");
  if (chart && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    const segs = Array.from(chart.querySelectorAll<SVGLineElement>(".eco-seg"));
    for (const s of segs) {
      const len = Math.hypot(
        Number(s.getAttribute("x2")) - Number(s.getAttribute("x1")),
        Number(s.getAttribute("y2")) - Number(s.getAttribute("y1")),
      );
      gsap.set(s, { strokeDasharray: len, strokeDashoffset: len });
    }
    ScrollTrigger.create({
      trigger: chart,
      start: "top 78%",
      once: true,
      onEnter: () => {
        const tl = gsap.timeline();
        segs.forEach((s, i) => {
          tl.to(s, { strokeDashoffset: 0, duration: 0.3, ease: "power1.inOut" }, i * 0.24);
        });
        tl.from(".eco-node", { opacity: 0, scale: 0.4, transformOrigin: "50% 50%", duration: 0.25, stagger: 0.12, ease: "power3.out" }, 0.2)
          .from("#eco-fork", { opacity: 0, duration: 0.5 }, segs.length * 0.24);
      },
    });
  }
</script>
