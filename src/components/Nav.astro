---
import { nav } from "../lib/site";
import Cuneiform from "./Cuneiform.astro";
import WishlistButton from "./WishlistButton.astro";

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(href + "/");
---

<header
  id="site-nav"
  class="fixed inset-x-0 top-0 z-50 border-b border-transparent bg-transparent transition-colors duration-500"
>
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between gap-4 px-6">
    <a
      href="/"
      class="flex items-center gap-2.5 font-display text-[0.95rem] font-semibold uppercase tracking-[0.18em] text-dust"
    >
      {/* SM logo — save the file as /public/assets/logo-sm.png (transparent).
          Falls back to the cuneiform mark until the file exists. */}
      <img
        src="/assets/logo-sm.png"
        alt=""
        class="h-7 w-auto"
        onerror="this.style.display='none';var f=document.getElementById('nav-logo-fallback');if(f)f.style.display='block'"
      />
      <span id="nav-logo-fallback" style="display:none">
        <Cuneiform marks={2} class="h-3.5 text-copper-400" />
      </span>
      Sumerian Merchant
    </a>

    <nav aria-label="Main" class="hidden items-center gap-6 lg:flex">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class={`text-sm transition-colors ${
              isActive(item.href) ? "text-barley-400" : "text-sand-300/80 hover:text-dust"
            }`}
          >
            {item.label}
          </a>
        ))
      }
      <WishlistButton size="sm" />
    </nav>

    <button
      type="button"
      id="nav-toggle"
      class="group inline-flex h-10 w-10 flex-col items-center justify-center gap-[5px] rounded-md border border-brick-700 lg:hidden"
      aria-expanded="false"
      aria-controls="nav-mobile"
      aria-label="Open menu"
    >
      <span class="h-[2px] w-5 bg-sand-200 transition-transform group-aria-expanded:translate-y-[7px] group-aria-expanded:rotate-45"></span>
      <span class="h-[2px] w-5 bg-sand-200 group-aria-expanded:opacity-0"></span>
      <span class="h-[2px] w-5 bg-sand-200 transition-transform group-aria-expanded:-translate-y-[7px] group-aria-expanded:-rotate-45"></span>
    </button>
  </div>

  <nav
    id="nav-mobile"
    aria-label="Mobile"
    class="hidden border-t border-brick-800 bg-bitumen/95 px-6 pb-6 pt-3 backdrop-blur-md lg:!hidden"
  >
    <ul class="flex flex-col">
      {
        nav.map((item) => (
          <li>
            <a href={item.href} class="block border-b border-brick-900 py-3 text-sand-200">
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
    <div class="pt-5">
      <WishlistButton class="w-full" />
    </div>
  </nav>
</header>

<script>
  const header = document.getElementById("site-nav")!;
  const toggle = document.getElementById("nav-toggle")!;
  const menu = document.getElementById("nav-mobile")!;

  const onScroll = () => {
    const open = toggle.getAttribute("aria-expanded") === "true";
    header.classList.toggle("nav-solid", window.scrollY > 12 || open);
  };
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });

  toggle.addEventListener("click", () => {
    const open = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!open));
    toggle.setAttribute("aria-label", open ? "Open menu" : "Close menu");
    menu.classList.toggle("hidden", open);
    onScroll();
  });
</script>
