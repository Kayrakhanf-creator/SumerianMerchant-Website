---
import Reveal from "./Reveal.astro";
import CuneiformDivider from "./CuneiformDivider.astro";

interface Props {
  eyebrow: string;
  title: string;
}
const { eyebrow, title } = Astro.props;
---

<div class="border-b border-brick-900 bg-gradient-to-b from-brick-950 to-transparent pb-14 pt-36">
  <div class="mx-auto max-w-6xl px-6">
    <Reveal>
      <p class="eyebrow">{eyebrow}</p>
    </Reveal>
    <Reveal delay={70}>
      <h1
        class="mt-4 max-w-[18ch] font-display text-4xl leading-[1.05] text-sand-200 [text-wrap:balance] md:text-6xl"
      >
        {title}
      </h1>
    </Reveal>
    {
      Astro.slots.has("lead") ? (
        <Reveal delay={140}>
          <div class="mt-6 max-w-[54ch] text-lg leading-relaxed text-sand-300/90">
            <slot name="lead" />
          </div>
        </Reveal>
      ) : null
    }
    <CuneiformDivider class="mt-10 justify-start" />
  </div>
</div>
